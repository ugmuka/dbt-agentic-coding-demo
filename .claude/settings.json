{
    "permissions": {
        "disableBypassPermissionsMode": "disable",
        "allow": [
            "Read",
            "Bash(git status)",
            "Bash(git diff *)",
            "Bash(git log *)",
            "Bash(git branch *)",
            "Bash(git switch *)",
            "Bash(git add *)",
            "Bash(git commit *)",
            "Bash(git commit-tree *)",
            "Bash(git stash *)",
            "Bash(git show *)",
            "Bash(git rev-parse *)",
            "Bash(git merge-base *)",
            "Bash(git fetch *)",
            "Bash(git pull *)",
            "Bash(gh issue *)",
            "Bash(gh pr view *)",
            "Bash(gh pr list *)",
            "Bash(gh pr checks *)",
            "Bash(gh api *)",
            "Bash(echo *)",
            "Bash(wc *)",
            "Bash(which *)",
            "Bash(ls *)",
            "Bash(jq *)",
            "Bash(grep *)",
            "Bash(sort *)",
            "Bash(find *)",
            "Bash(xargs *)",
            "Bash(awk *)",
            "Bash(sed *)",
            "Bash(cut *)",
            "Bash(tr *)",
            "Bash(uniq *)",
            "Bash(diff *)",
            "Bash(tee /tmp/*)",
            "Bash(ruby --version)",
            "Bash(node --version)",
            "Bash(npx --version)",
            "Bash(python3 --version)",
            "Bash(git --version)",
            "Bash(bundle *)",
            "Bash(rubocop *)",
            "Bash(rspec *)",
            "Bash(rails *)",
            "Bash(dbt *)",
            "Bash(uv sync)",
            "Bash(uv run ruff *)",
            "Bash(uv run pytest *)",
            "Bash(uv tool run ast-grep *)",
            "Bash(ruff *)",
            "Bash(terraform init *)",
            "Bash(terraform plan *)",
            "Bash(terraform validate *)",
            "Bash(terraform fmt *)",
            "Bash(terraform show *)",
            "Bash(terraform output *)",
            "Bash(terragrunt init *)",
            "Bash(terragrunt plan *)",
            "Bash(terragrunt validate *)",
            "Bash(terragrunt run-all plan *)",
            "Bash(terragrunt run-all validate *)",
            "Bash(terragrunt output *)",
            "Bash(docker compose up *)",
            "Bash(docker compose down *)",
            "Bash(docker compose restart *)",
            "Bash(docker compose config *)",
            "Bash(docker compose ps *)",
            "Bash(docker compose logs *)",
            "Write(/tmp/**)"
        ],
        "deny": [
            "Bash(rm *)",
            "Bash(rmdir *)",
            "Bash(unlink *)",
            "Bash(shred *)",
            "Bash(find * -delete*)",
            "Bash(rsync * --delete*)",
            "Bash(sudo *)",
            "Bash(su *)",
            "Bash(curl *)",
            "Bash(wget *)",
            "Bash(ssh *)",
            "Bash(scp *)",
            "Bash(nc *)",
            "Bash(ncat *)",
            "Bash(telnet *)",
            "Bash(git push *)",
            "Bash(git reset *)",
            "Bash(osascript *)",
            "Bash(open *)",
            "Bash(security *)",
            "Bash(pbcopy *)",
            "Bash(pbpaste *)",
            "Bash(gh api -X POST *)",
            "Bash(gh api -X PUT *)",
            "Bash(gh api -X PATCH *)",
            "Bash(gh api -X DELETE *)",
            "Bash(gh api --method POST *)",
            "Bash(gh api --method PUT *)",
            "Bash(gh api --method PATCH *)",
            "Bash(gh api --method DELETE *)",
            "Bash(rails generate *)",
            "Bash(rails g *)",
            "Bash(terraform init -upgrade *)",
            "Bash(terragrunt init -upgrade *)",
            "Bash(terraform destroy *)",
            "Bash(terragrunt destroy *)",
            "Bash(terragrunt run-all destroy *)",
            "Bash(docker compose run *)",
            "Bash(docker compose exec *)",
            "Bash(* .env*)",
            "Read(./.env)",
            "Edit(./.env)",
            "Write(./.env)",
            "Read(./.env.*)",
            "Edit(./.env.*)",
            "Write(./.env.*)",
            "Read(./**/.env)",
            "Edit(./**/.env)",
            "Write(./**/.env)",
            "Read(./**/.env.*)",
            "Edit(./**/.env.*)",
            "Write(./**/.env.*)",
            "Read(/secrets/**)",
            "Edit(/secrets/**)",
            "Write(/secrets/**)",
            "Read(~/.dbt/**)",
            "Edit(~/.dbt/**)",
            "Write(~/.dbt/**)",
            "Read(./infra/terraform/live/dev/snowflake/keys/**)",
            "Edit(./infra/terraform/live/dev/snowflake/keys/**)",
            "Write(./infra/terraform/live/dev/snowflake/keys/**)",
            "Read(./**/*.p8)",
            "Read(./**/*.pem)",
            "Read(./**/*.key)",
            "Edit(~/.zshrc)",
            "Write(~/.zshrc)",
            "Edit(~/.bashrc)",
            "Write(~/.bashrc)"
        ]
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/capture_signal.sh"
                    }
                ]
            },
            {
                "matcher": "AskUserQuestion",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/capture_signal.sh"
                    }
                ]
            },
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/exec_rubocop.sh"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/check_threshold.sh"
                    }
                ]
            }
        ]
    },
    "language": "ja",
    "sandbox": {
        "enabled": true,
        "autoAllowBashIfSandboxed": true,
        "network": {
            "allowedDomains": [
                "pypi.org",
                "files.pythonhosted.org",
                "docs.python.org",
                "rubygems.org",
                "api.rubygems.org",
                "bundler.io",
                "guides.rubyonrails.org",
                "api.rubyonrails.org",
                "docs.getdbt.com",
                "hub.getdbt.com",
                "registry.getdbt.com",
                "registry.terraform.io",
                "developer.hashicorp.com",
                "releases.hashicorp.com",
                "checkpoint-api.hashicorp.com",
                "github.com",
                "api.github.com",
                "raw.githubusercontent.com",
                "registry-1.docker.io",
                "auth.docker.io",
                "index.docker.io"
            ]
        }
    }
}